<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<Title>CodeWF.AvaloniaControls.DataGrid</Title>
		<TargetFrameworks>net8.0;net9.0;net10.0;net11.0</TargetFrameworks>
		<Version>$(CodeWFAvaloniaControlsDataGridVersion)</Version>
		<Nullable>enable</Nullable>
		<LangVersion>latest</LangVersion>
		<OutputType>Library</OutputType>
		<IsPackable>true</IsPackable>
		<Description>封装一些基于 Avalonia 的 DataGrid 控件扩展，支持列取消排序等扩展功能。Encapsulate some extensions for Avalonia DataGrid controls, including tri-state unsort support.</Description>
		<PackageIcon>logo.png</PackageIcon>
		<PackageTags>avalonia ui,datagrid,controls,custom,unsort</PackageTags>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
		<RootNamespace>CodeWF.AvaloniaControls.DataGrid</RootNamespace>
		<AssemblyName>CodeWF.AvaloniaControls.DataGrid</AssemblyName>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Avalonia.Controls.DataGrid" />
		<PackageReference Include="Avalonia.Controls.TreeDataGrid" />
		<PackageReference Include="Semi.Avalonia.DataGrid" />
		<PackageReference Include="Semi.Avalonia.TreeDataGrid" />
	</ItemGroup>

	<ItemGroup>
		<None Include="logo.png" Pack="true" PackagePath="" />
	</ItemGroup>
</Project>
